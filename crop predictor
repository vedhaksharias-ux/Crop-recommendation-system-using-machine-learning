class CropPredictor:
    """Make crop recommendations based on input parameters"""
    
    def __init__(self, model_path='crop_recommendation_model.pkl', scaler_path='scaler.pkl'):
        self.model = joblib.load(model_path)
        self.scaler = joblib.load(scaler_path)
        self.crop_descriptions = {
